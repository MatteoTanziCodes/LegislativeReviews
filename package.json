{
	"name": "core",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"review": "python scripts/run_local_review_release.py",
		"smoke-test": "python scripts/smoke_test_release_setup.py",
		"preprocess": "python scripts/run_local_review_release.py --preprocess-only",
		"refresh-laws": "python scripts/run_local_review_release.py --refresh-source --preprocess-only",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"deploy:staging": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env staging",
		"deploy:production": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env production",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"preview:staging": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env staging",
		"preview:production": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:staging": "wrangler types --env staging --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:production": "wrangler types --env production --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.17.3",
		"next": "^16.2.1",
		"react": "19.1.5",
		"react-dom": "19.1.5"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "^16.2.1",
		"node-addon-api": "^8.5.0",
		"node-gyp": "^12.2.0",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.76.0"
	}
}
