CLAUDE_API_KEY=your_claude_api_key

# Dataset storage roots for the Python pipeline.
# Relative paths are resolved from the project root.
LEGISLATIVE_REVIEW_DATA_ROOT=docs\canadian-laws
# Optional explicit override when processed parquet files live elsewhere.
# LEGISLATIVE_REVIEW_PROCESSED_DIR=docs\canadian-laws\processed

# Optional embedding tuning
FASTEMBED_THREADS=4

# Optional staged publication settings for the dashboard frontend.
# Set to a positive integer to reveal that many reviewed results per day.
# Set to "all" to show the full reviewed dataset immediately.
LEGISLATIVE_REVIEW_DAILY_RELEASE=all
# Optional explicit rollout start timestamp. If omitted, the dashboard uses
# the exported summary's lastUpdated timestamp as the first release day.
# LEGISLATIVE_REVIEW_ROLLOUT_START_DATE=2026-04-04T00:00:00-04:00
LEGISLATIVE_REVIEW_ROLLOUT_TIMEZONE=America/Toronto

# Cloudflare R2 publish settings for the Python review runner.
# Match the bucket to the Wrangler environment you are targeting.
# Examples:
#   staging -> legislative-review-data-staging
#   production -> legislative-review-data-production
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_BUCKET=legislative-review-data-staging
CLOUDFLARE_R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_SUMMARY_KEY=review-summary.json
CLOUDFLARE_R2_DETAILS_KEY=review-details.json
