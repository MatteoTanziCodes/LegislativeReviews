CLAUDE_API_KEY=your_claude_api_key
LEGISLATIVE_REVIEW_ADMIN_TOKEN=your_dashboard_admin_token
# Optional dedicated cookie signing secret for /legislative-reviews/admin.
# If omitted, the admin token is reused as the session signing secret.
# LEGISLATIVE_REVIEW_SESSION_SECRET=your_session_signing_secret

# GitHub Actions dispatch settings for /legislative-reviews/admin.
# In Cloudflare production, set GITHUB_REVIEW_WORKFLOW_TOKEN as a Worker secret.
GITHUB_REVIEW_WORKFLOW_TOKEN=your_github_actions_dispatch_token
GITHUB_REVIEW_WORKFLOW_OWNER=MatteoTanziCodes
GITHUB_REVIEW_WORKFLOW_REPO=LegislativeReviews
GITHUB_REVIEW_WORKFLOW_ID=review-pipeline.yml
GITHUB_REVIEW_WORKFLOW_REF=main
GITHUB_REVIEW_WORKFLOW_ENVIRONMENT=staging

# Dataset storage roots for the Python pipeline.
# Set LEGISLATIVE_REVIEW_DATA_ROOT on non-Windows hosts.
LEGISLATIVE_REVIEW_DATA_ROOT=E:\Programming\buildcanada\canadian-laws
# Optional explicit override when processed parquet files live elsewhere.
# LEGISLATIVE_REVIEW_PROCESSED_DIR=E:\Programming\buildcanada\canadian-laws\processed

# Optional embedding tuning
FASTEMBED_THREADS=4

# Cloudflare R2 publish settings for the Python review runner.
# Match the bucket to the Wrangler environment you are targeting.
# Examples:
#   staging -> legislative-review-data-staging
#   production -> legislative-review-data-production
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_BUCKET=legislative-review-data-staging
CLOUDFLARE_R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_SUMMARY_KEY=review-summary.json
CLOUDFLARE_R2_DETAILS_KEY=review-details.json
CLOUDFLARE_R2_ADMIN_STATE_KEY=review-admin-state.json
